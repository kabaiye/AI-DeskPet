# AI 平台 API Key
# 默认使用智谱AI（免费），也可切换为阿里云百炼等其他 OpenAI 兼容平台
# 智谱AI申请地址: https://open.bigmodel.cn/usercenter/proj-mgmt/apikeys
DASHSCOPE_API_KEY=your_api_key_here

# AI 平台 Base URL（可选，默认智谱AI）
# 智谱AI: https://open.bigmodel.cn/api/paas/v4/
# 阿里云百炼: https://dashscope.aliyuncs.com/compatible-mode/v1
# DASHSCOPE_BASE_URL=https://open.bigmodel.cn/api/paas/v4/

# AI 模型名称（可选，默认使用智谱免费模型）
# AI_TEXT_MODEL=glm-4-flash-250414
# AI_VISION_MODEL=glm-4v-flash
